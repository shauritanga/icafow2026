# ─────────────────────────────────────────────────────────────
# ICAFoW 2026 — environment configuration
# Copy to ".env" and fill in real values.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Display-only USD->TZS rate shown in the UI (keep in sync with USD_TO_TZS_RATE)
NEXT_PUBLIC_USD_TO_TZS="2600"

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/icafow?schema=public"

# NextAuth (admin dashboard)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Seed admin (used by prisma/seed.ts)
ADMIN_EMAIL="admin@icafow.org"
ADMIN_PASSWORD="ChangeMe123!"

# ─── Selcom Payment Gateway ───────────────────────────────────
# Get these from your Selcom merchant dashboard / integration team.
# Sandbox base URL: https://apigwtest2.selcommobile.com
# Production base URL: https://apigw.selcommobile.com
SELCOM_BASE_URL="https://apigwtest2.selcommobile.com"
SELCOM_API_KEY=""
SELCOM_API_SECRET=""
SELCOM_VENDOR_ID=""
# Currency Selcom charges in (Selcom settles in TZS).
SELCOM_CURRENCY="TZS"
# USD -> TZS conversion rate used to compute the charged amount.
USD_TO_TZS_RATE="2600"
# Timeout (ms) for each outbound Selcom HTTP call. Optional, defaults to 15000.
SELCOM_TIMEOUT_MS="15000"

# All of SELCOM_API_KEY / SELCOM_API_SECRET / SELCOM_VENDOR_ID and
# NEXT_PUBLIC_APP_URL are REQUIRED — payments fail fast (with a clear error) if
# any are missing. There is no mock gateway; point SELCOM_BASE_URL at the
# sandbox for testing and the production URL for live.
