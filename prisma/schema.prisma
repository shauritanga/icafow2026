// ICAFoW 2026 — data model
// Postgres + Prisma. Run: npx prisma migrate dev && npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RegistrationType {
  ATTENDEE
  SPONSOR
  EXHIBITOR
  PARTNER
  SPEAKER
  PITCH
}

enum RegistrationStatus {
  PENDING       // created, awaiting payment / review
  CONFIRMED     // paid or approved
  CANCELLED
  WAITLISTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum Currency {
  USD
  TZS
}

enum NotificationType {
  EMAIL
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  COMPLETED
  FAILED
}

model NotificationJob {
  id          String             @id @default(cuid())
  type        NotificationType
  status      NotificationStatus @default(PENDING)
  payload     Json               // Stores { to, subject, body, etc. }
  errorLog    String?            @db.Text
  retryCount  Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum PaymentMethod {
  CARD
  TIGOPESA
  MPESA
  AIRTELMONEY
  UNSET
}

/// One row per registration of any audience type.
model Registration {
  id        String             @id @default(cuid())
  reference String             @unique // e.g. ICA-7F3K9Q
  type      RegistrationType
  status    RegistrationStatus @default(PENDING)

  // Contact / lead
  fullName     String
  email        String
  phone        String?
  organization String?
  jobTitle     String?
  country      String?

  // Selected product (pass id / booth id / tier id) + display label
  packageId    String?
  packageLabel String?

  // Amount owed for this registration (snapshot at creation time)
  amount   Float    @default(0)
  currency Currency @default(USD)

  // Free-form, type-specific details captured from each form
  details Json?

  notes     String?
  payments  Payment[]
  paper     Paper?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type, status])
  @@index([email])
}

/// A payment attempt against a registration. Multiple allowed (retries).
model Payment {
  id        String        @id @default(cuid())
  reference String        @unique // gateway order reference / transid
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod @default(UNSET)

  amount   Float
  currency Currency @default(USD)

  // Exact charge sent to the gateway (snapshot for reconciliation)
  chargeAmount   Int?      // integer minor/whole unit actually charged (TZS)
  chargeCurrency Currency? @default(TZS)
  attempt        Int       @default(1) // retry counter → unique gateway order_id

  // Selcom fields
  selcomOrderId     String? @unique // per-attempt order_id sent to Selcom
  selcomTransId     String? // Selcom transaction id (transid)
  selcomReference   String? // Selcom reference
  selcomPaymentToken String?
  checkoutUrl       String?
  gatewayPayload    Json?   // raw responses / webhook bodies for audit
  failureReason     String?

  paidAt    DateTime?
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([registrationId])
}

/// Research paper attached to an attendee (Researcher Pass) registration.
model Paper {
  id       String  @id @default(cuid())
  title    String
  abstract String  @db.Text
  track    String?
  keywords String?
  authors  Json?   // [{name, email, affiliation}]
  fileUrl  String?
  status   String  @default("pending") // pending | under_review | accepted | rejected

  registrationId String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// General contact / enquiry messages.
model ContactMessage {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  organization String?
  subject      String
  message      String   @db.Text
  handled      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

/// Admin / staff users for the dashboard (NextAuth credentials).
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("admin") // admin | staff | viewer
  phone        String?
  avatarData   String?  @db.Text
  fcmTokens    String[] // Array of push notification tokens
  inAppNotifications InAppNotification[]
  createdAt    DateTime @default(now())
}

/// Global dynamic configuration (socials, contact info).
model SiteSetting {
  id        String   @id @default("global")
  data      Json
  updatedAt DateTime @updatedAt
}

/// Persistent in-app notifications for admins (the bell icon).
model InAppNotification {
  id        String   @id @default(cuid())
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  title     String
  body      String   @db.Text
  read      Boolean  @default(false)
  url       String?  // Optional link
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([read])
}
